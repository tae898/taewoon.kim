---
import { site } from '../site';
import SocialIcon from './SocialIcon.astro';

const socialLinks = [...site.social.filter((item) => item.label !== 'YouTube'), { label: 'CV', href: site.cv }];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__meta">
      <small>{site.author}</small>
      <div class="legal-links">
        <a class="social-link" href="/privacy-policy/">Privacy</a>
        <button class="social-link social-link--button" type="button" data-cookie-settings>Cookie settings</button>
      </div>
    </div>

    <div class="social-list">
      {socialLinks.map((item) => (
        <a
          class="social-link social-link--icon-only"
          href={item.href}
          aria-label={item.label}
          title={item.label}
          target="_blank"
          rel="noreferrer"
        >
          <SocialIcon label={item.label} />
        </a>
      ))}
    </div>
  </div>
</footer>