---
import { site } from '../site';

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/">
      <img src={site.avatar} alt={site.author} />
      <span>{site.title}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {site.nav.map((item) => {
        const isActive = !item.external && pathname.startsWith(item.href);

        return (
          <a
            href={item.href}
            aria-current={isActive ? 'page' : undefined}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noreferrer' : undefined}
          >
            {item.label}
          </a>
        );
      })}
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Theme: System">
        <span class="theme-toggle__icon theme-toggle__icon--system" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <rect x="4" y="5" width="16" height="11" rx="2"></rect>
            <path d="M9 19h6"></path>
            <path d="M12 16v3"></path>
          </svg>
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--light" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M4.93 19.07l1.41-1.41"></path>
            <path d="M17.66 6.34l1.41-1.41"></path>
          </svg>
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M20 14.5A7.5 7.5 0 0 1 9.5 4 8 8 0 1 0 20 14.5Z"></path>
          </svg>
        </span>
        <span class="sr-only" data-theme-status>Theme: System</span>
      </button>
    </nav>
  </div>
</header>