---
import { site } from '../site';

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/">
      <img src={site.avatar} alt={site.author} />
      <span>{site.title}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {site.nav.map((item) => {
        const isExternal = item.href.startsWith('http');
        const isSectionLink = item.href.startsWith('/#');
        const isActive = !isExternal && !isSectionLink && pathname.startsWith(item.href);

        return (
          <a
            href={item.href}
            aria-current={isActive ? 'page' : undefined}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noreferrer' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>

  <script is:inline>
    const syncHeaderScrollOffset = () => {
      const header = document.querySelector('.site-header');
      if (!header) {
        return;
      }

      const headerHeight = Math.ceil(header.getBoundingClientRect().height);
      document.documentElement.style.setProperty('--header-scroll-offset', `${headerHeight}px`);
    };

    syncHeaderScrollOffset();

    if ('ResizeObserver' in window) {
      const header = document.querySelector('.site-header');
      if (header) {
        const observer = new ResizeObserver(() => {
          syncHeaderScrollOffset();
        });
        observer.observe(header);
      }
    }

    window.addEventListener('resize', syncHeaderScrollOffset);

    const initSectionNavTracking = () => {
      if (window.location.pathname !== '/') {
        return;
      }

      const sectionLinks = Array.from(document.querySelectorAll('.site-nav a[href^="/#"]'));
      const trackedSections = sectionLinks
        .map((link) => {
          const id = link.getAttribute('href')?.slice(2);
          const section = id ? document.getElementById(id) : null;
          return section ? { link, section } : null;
        })
        .filter(Boolean);

      if (trackedSections.length === 0) {
        return;
      }

      const setActiveLink = (activeId) => {
        for (const item of trackedSections) {
          if (item.section.id === activeId) {
            item.link.setAttribute('aria-current', 'location');
          } else {
            item.link.removeAttribute('aria-current');
          }
        }
      };

      const updateActiveLink = () => {
        const threshold = Math.min(window.innerHeight * 0.35, 240);
        let activeId = trackedSections[0]?.section.id;

        for (const item of trackedSections) {
          if (item.section.getBoundingClientRect().top <= threshold) {
            activeId = item.section.id;
          }
        }

        if (activeId) {
          setActiveLink(activeId);
        }
      };

      updateActiveLink();
      window.addEventListener('scroll', updateActiveLink, { passive: true });
      window.addEventListener('resize', updateActiveLink);
      window.addEventListener('hashchange', updateActiveLink);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSectionNavTracking, { once: true });
    } else {
      initSectionNavTracking();
    }
  </script>
</header>