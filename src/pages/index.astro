---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getAllTags, sortPosts } from '../utils/blog';

const posts = sortPosts(await getCollection('blog'));
const featuredPosts = posts.slice(0, 6);
const tags = getAllTags(posts).slice(0, 8);
---

<BaseLayout title="I'm Taewoon" description="AI Researcher & Engineer">
  <section class="hero">
    <div class="eyebrow">AI Researcher and Engineer</div>
    <h1>Building ideas that connect learning, memory, and real systems.</h1>
    <p>
      I write about reinforcement learning, knowledge graphs, language models, and the
      engineering choices that make AI systems actually usable.
    </p>
    <div class="hero__actions">
      <a class="button" href="/blog/">Read the blog</a>
      <a class="button button--secondary" href="/contact/">Work with me</a>
    </div>
    <div class="tag-list">
      {tags.map((tag) => (
        <a class="tag" href={`/tags/#${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <div class="eyebrow">Latest Writing</div>
        <h2>Recent posts</h2>
      </div>
      <a class="button button--secondary" href="/feed.xml">RSS feed</a>
    </div>

    <div class="grid posts-grid">
      {featuredPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>