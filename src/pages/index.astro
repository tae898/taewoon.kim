---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogBrowser from '../components/BlogBrowser.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { blogListing, getSocialLinks, homePage } from '../site';
import { sortPosts } from '../utils/blog';

const posts = sortPosts(await getCollection('blog'));
const aboutSocialLinks = getSocialLinks('about');
---

<BaseLayout title="I'm Taewoon" description="AI Researcher & Engineer">
  <section id={homePage.intro.id} class="hero hero--home">
    <div class="hero__copy">
      <h1>{homePage.intro.title}</h1>
      <p class="lede">{homePage.intro.lede}</p>
    </div>

    <SocialLinks
      links={aboutSocialLinks}
      listClass="hero__actions hero__actions--social"
      variant="button"
      iconOnly={true}
    />
  </section>

  <section id={homePage.blog.id} class="section section--blog">
    <div class="section-header">
      <div>
        <h2>{homePage.blog.label}</h2>
        <p>{homePage.blog.description}</p>
      </div>
    </div>

    <BlogBrowser posts={posts} postsPerPage={blogListing.postsPerPage} sectionId={homePage.blog.id} />
  </section>
</BaseLayout>