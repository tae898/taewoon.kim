---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTagGroups, getTagUrl, sortPosts } from '../../utils/blog';

const posts = sortPosts(await getCollection('blog'));
const tags = getAllTagGroups(posts);
---

<BaseLayout title="Tags" description="Browse posts by topic.">
  <header class="page-header">
    <div class="eyebrow">Browse</div>
    <h1>Tags</h1>
    <p>Browse the archive by topic instead of date.</p>
  </header>

  <section class="tag-panel panel" style="padding: 1.5rem; margin-bottom: 1.5rem;">
    <div class="tag-list">
      {tags.map((tag) => (
        <a class="tag" href={getTagUrl(tag.name)}>{tag.name}</a>
      ))}
    </div>
  </section>

  <div class="grid">
    {tags.map((tag) => (
      <section class="panel" style="padding: 1.5rem;">
        <h2>{tag.name}</h2>
        <p class="meta-copy">{tag.count} post{tag.count === 1 ? '' : 's'}</p>
        {tag.aliases.length > 1 && (
          <p class="meta-copy">Also groups: {tag.aliases.filter((alias) => alias !== tag.name).join(', ')}</p>
        )}
        <p><a href={getTagUrl(tag.name)}>View posts with this tag</a></p>
      </section>
    ))}
  </div>
</BaseLayout>