---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogBrowser from '../../components/BlogBrowser.astro';
import { blogListing, homePage } from '../../site';
import { sortPosts } from '../../utils/blog';

const posts = sortPosts(await getCollection('blog'));
---

<BaseLayout title="Blog" description="Notes on AI, machine learning, reinforcement learning, and engineering.">
  <header class="page-header">
    <div class="eyebrow">Archive</div>
    <h1>Blog</h1>
    <p>Notes, essays, and research fragments.</p>
  </header>

  <BlogBrowser posts={posts} postsPerPage={blogListing.postsPerPage} sectionId={homePage.blog.id} />
</BaseLayout>