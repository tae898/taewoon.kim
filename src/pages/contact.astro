---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { site } from '../site';

const socialLinks = [...site.social, { label: 'CV', href: site.cv }];
---

<BaseLayout
  title="Contact"
  description="I work on AI research, engineering, and consulting, and I am open to consulting and project work."
>
  <section class="panel prose" style="padding: 1.75rem;">
    <header class="page-header">
      <div class="eyebrow">Contact</div>
      <h1>Get in touch.</h1>
      <p>I work on AI research, engineering, and consulting, and I am open to consulting and project work.</p>
    </header>

    <div class="social-list">
      {socialLinks.map((item) => (
        <a class="social-link" href={item.href} target="_blank" rel="noreferrer">
          <SocialIcon label={item.label} />
          {item.label}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>