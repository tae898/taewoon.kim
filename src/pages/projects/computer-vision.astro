---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Computer Vision" description="Making the machines see the world as we do.">
  <section class="panel prose" style="padding: 1.75rem;">
    <header class="page-header">
      <div class="eyebrow">Project</div>
      <h1>Computer Vision</h1>
      <p>Making the machines see the world as we do.</p>
    </header>

    <h2>
      <a href="https://github.com/tae898/room-classification">Room classifier</a>
    </h2>

    <div style="position: relative; padding-bottom: 56.25%; overflow: hidden; border-radius: 1rem; border: 1px solid rgba(31, 27, 22, 0.12);">
      <iframe
        style="position: absolute; inset: 0; width: 100%; height: 100%;"
        width="100%"
        height="100%"
        allowfullscreen
        allow="autoplay"
        src="https://www.youtube.com/embed/cM01mHaAtNA?si=FQav-tAgMyDB3Ua3"
      ></iframe>
    </div>
  </section>
</BaseLayout>